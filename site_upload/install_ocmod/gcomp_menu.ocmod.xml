<?xml version="1.0" encoding="utf-8"?>
<modification>
  <name>GCOMP - Configurator Menu Item</name>
  <code>gcomp_menu</code>
  <version>6.0</version>
  <author>gcomp.ge</author>

  <file path="admin/controller/common/column_left.php">
    <operation>
      <search><![CDATA[// GCOMP menu items inserted here by sub-mods]]></search>
      <add position="after"><![CDATA[
			if ($this->user->hasPermission('access', 'extension/module/configurator')) {
				$gcomp[] = array(
					'name'     => 'კონფიგურატორი',
					'href'     => $this->url->link('extension/module/configurator', 'user_token=' . $this->session->data['user_token'], true),
					'children' => array()
				);
			}]]></add>
    </operation>
  </file>

</modification>
